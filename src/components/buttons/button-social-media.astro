---
const {
  Icon,
  label,
  url,
  color = "bg-white",
  text = "text-black",
} = Astro.props;
---

<a
  href={url}
  target="_blank"
  rel="noopener noreferrer nofollow"
  class={`group h-40 w-200 cursor-pointer overflow-hidden rounded-[60px] ${color} ${text} p-5 transition-all duration-300 hover:h-60`}
  aria-label={label}
  title={label}
>
  <span
    class="ml-3 inline-block pb-4 font-sans text-xs font-semibold transition-all duration-300 group-hover:translate-x-60 sm:text-base md:text-2xl"
    >{label}</span
  >
  <Icon class="mt-4 size-30 w-16 rotate-20 sm:w-36" />
</a>
